CompileFlags:
  CompilationDatabase: build
Diagnostics:
  ClangTidy:
    Add: [performance-*,clang-analyzer-*,bugprone-*]
    Remove: [bugprone-narrowing-conversions,performance-no-int-to-ptr,bugprone-easily-swappable-parameters]
---
If:
  PathMatch:
    - editor/src/.*
    - editor/include/.*
CompileFlags:
  CompilationDatabase: build_editor
---
If:
  PathMatch:
    - tests/src/.*
    - tests/include/.*
CompileFlags:
  CompilationDatabase: build_tests
